# ─────────────────────────────────────────────────────
# DATABASE — Supabase PostgreSQL via Prisma + pgBouncer
# ─────────────────────────────────────────────────────
# Use the connection pooler URL (port 6543) for runtime queries
DATABASE_URL="postgresql://postgres.<your-project-ref>:<your-db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Use the direct URL (port 5432) for Prisma migrations only
DIRECT_URL="postgresql://postgres.<your-project-ref>:<your-db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ─────────────────────────────────────────────────────
# SUPABASE — Storage + Client
# Found at: Supabase Dashboard > Project Settings > API
# ─────────────────────────────────────────────────────
# Your Supabase project base URL
NEXT_PUBLIC_SUPABASE_URL="https://<your-project-ref>.supabase.co"
# The anon/public key (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
# The service_role key — SERVER SIDE ONLY, never use NEXT_PUBLIC_ prefix
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ─────────────────────────────────────────────────────
# NEXTAUTH
# ─────────────────────────────────────────────────────
# Must be at least 32 random characters — generate with: openssl rand -base64 32
AUTH_SECRET="your-super-secret-key-change-this-in-production-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# ─────────────────────────────────────────────────────
# ADMIN SEED CREDENTIALS
# Used only by: prisma/seed.ts on first setup
# Change password after first login via Admin > Settings
# ─────────────────────────────────────────────────────
ADMIN_EMAIL="admin@priyajewellery.com"
ADMIN_PASSWORD="YourSecurePassword123"

# ─────────────────────────────────────────────────────
# PUBLIC SITE CONFIG
# ─────────────────────────────────────────────────────
# WhatsApp number in international format without + (e.g. 917367997766 = +91 7367997766)
# NOTE: This is a fallback only — the live value is managed via Admin > Settings > WhatsApp
NEXT_PUBLIC_WHATSAPP_NUMBER="917367997766"
NEXT_PUBLIC_SITE_URL="https://yoursite.com"
NEXT_PUBLIC_SITE_NAME="Priya Jewellery"

# ─────────────────────────────────────────────────────
# VERCEL DEPLOYMENT CHECKLIST
# Set ALL of the above variables in: Vercel > Project > Settings > Environment Variables
# The following must be set for production:
#   DATABASE_URL          — Supabase pooler URL
#   DIRECT_URL            — Supabase direct URL (for migrations)
#   NEXT_PUBLIC_SUPABASE_URL
#   NEXT_PUBLIC_SUPABASE_ANON_KEY
#   SUPABASE_SERVICE_ROLE_KEY
#   AUTH_SECRET           — Generate new strong secret for prod
#   NEXTAUTH_URL          — Your production domain (e.g. https://priyajewellery.com)
#   NEXT_PUBLIC_SITE_URL  — Your production domain
# ─────────────────────────────────────────────────────
