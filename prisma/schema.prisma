// Priya Jewellery — Prisma Schema (Prisma v7)
// Note: datasource URL is now configured in prisma.config.ts
// To switch to PostgreSQL: change provider to "postgresql" and update DATABASE_URL

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// ADMIN
// ─────────────────────────────────────────
model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String   @default("Admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─────────────────────────────────────────
// CATEGORY
// ─────────────────────────────────────────
model Category {
  id           String    @id @default(cuid())
  name         String
  slug         String    @unique
  description  String?
  imageUrl     String?
  group        String?   // e.g. "Gold Plated", "Anti Tarnish", "American Diamond"
  metaTitle    String?
  metaDesc     String?
  displayOrder Int       @default(0)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  products     Product[]
}

// ─────────────────────────────────────────
// PRODUCT
// ─────────────────────────────────────────
model Product {
  id              String          @id @default(cuid())
  name            String
  slug            String          @unique
  sku             String?
  categoryId      String
  category        Category        @relation(fields: [categoryId], references: [id])

  price           Float
  mrp             Float?
  shortDesc       String?
  description     String?

  stockQty        Int             @default(0)
  stockStatus     String          @default("IN_STOCK")

  isPublished     Boolean         @default(false)
  isBestseller    Boolean         @default(false)
  isNewArrival    Boolean         @default(true)
  isFeatured      Boolean         @default(false)

  metaTitle       String?
  metaDesc        String?

  viewCount       Int             @default(0)
  whatsappClicks  Int             @default(0)
  wishlistCount   Int             @default(0)

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  images          ProductImage[]
  variants        ProductVariant[]
  video           ProductVideo?
  comboItems      ComboItem[]     @relation("ParentProduct")
  reviews         Review[]
  analyticsEvents AnalyticsEvent[]
  instagramPosts  InstagramPost[]
}

// ─────────────────────────────────────────
// PRODUCT IMAGE
// ─────────────────────────────────────────
model ProductImage {
  id           String  @id @default(cuid())
  productId    String
  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url          String
  altText      String?
  isPrimary    Boolean @default(false)
  displayOrder Int     @default(0)
}

// ─────────────────────────────────────────
// PRODUCT VARIANT (size/length options)
// ─────────────────────────────────────────
model ProductVariant {
  id         String  @id @default(cuid())
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name       String
  value      String
  priceDelta Float   @default(0)
  stockQty   Int     @default(0)
  isActive   Boolean @default(true)
}

// ─────────────────────────────────────────
// PRODUCT VIDEO
// ─────────────────────────────────────────
model ProductVideo {
  id        String  @id @default(cuid())
  productId String  @unique
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  thumbnail String?
}

// ─────────────────────────────────────────
// COMBO ITEM (necklace+earring set)
// ─────────────────────────────────────────
model ComboItem {
  id               String  @id @default(cuid())
  productId        String
  product          Product @relation("ParentProduct", fields: [productId], references: [id], onDelete: Cascade)
  relatedProductId String
  label            String?
}

// ─────────────────────────────────────────
// REVIEW
// ─────────────────────────────────────────
model Review {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerName  String
  customerPhoto String?
  rating        Int      @default(5)
  text          String
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())
}

// ─────────────────────────────────────────
// LEAD (newsletter / WhatsApp broadcast opt-in)
// ─────────────────────────────────────────
model Lead {
  id        String   @id @default(cuid())
  name      String
  phone     String
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────
// HERO BANNER (homepage carousel)
// ─────────────────────────────────────────
model HeroBanner {
  id           String   @id @default(cuid())
  imageUrl     String
  title        String?
  subtitle     String?
  ctaText      String?
  ctaLink      String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

// ─────────────────────────────────────────
// INSTAGRAM POST (shoppable gallery)
// ─────────────────────────────────────────
model InstagramPost {
  id           String   @id @default(cuid())
  imageUrl     String
  caption      String?
  productId    String?
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

// ─────────────────────────────────────────
// TRUST BADGE (homepage row)
// ─────────────────────────────────────────
model TrustBadge {
  id           String  @id @default(cuid())
  icon         String
  text         String
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)
}

// ─────────────────────────────────────────
// TESTIMONIAL
// ─────────────────────────────────────────
model Testimonial {
  id           String  @id @default(cuid())
  name         String
  photo        String?
  rating       Int     @default(5)
  text         String
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)
}

// ─────────────────────────────────────────
// BUDGET RANGE (Shop by Budget section)
// ─────────────────────────────────────────
model BudgetRange {
  id           String  @id @default(cuid())
  label        String
  minPrice     Float   @default(0)
  maxPrice     Float?
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)
}

// ─────────────────────────────────────────
// POLICY PAGE (editable static pages)
// ─────────────────────────────────────────
model PolicyPage {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────
// SETTINGS (singleton row — id always "main")
// ─────────────────────────────────────────
model Settings {
  id               String  @id @default("main")
  storeName        String  @default("Priya Jewellery")
  whatsappNumber   String  @default("917367997766")
  whatsappTemplate String  @default("Hi Priya Jewellery! I am interested in:\n {product_name}\n Rs.{price}\n Size/Variant: {variant}\n Link: {url}\nPlease confirm availability and delivery details.")
  announcementText String  @default("Free shipping in-city on orders above Rs.1499 | New Arrivals Every Week")
  phone            String  @default("+91 7367997766")
  email            String  @default("priyajewellery@gmail.com")
  address          String  @default("")
  mapEmbed         String  @default("")
  businessHours    String  @default("Mon-Sat: 10am - 7pm")
  instagramUrl     String  @default("")
  facebookUrl      String  @default("")
  youtubeUrl       String  @default("")
  saleMessage      String  @default("")
  saleCountdownEnd String?
  logoUrl          String  @default("")
}

// ─────────────────────────────────────────
// ANALYTICS EVENT
// ─────────────────────────────────────────
model AnalyticsEvent {
  id        String   @id @default(cuid())
  type      String
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  sessionId String?
  createdAt DateTime @default(now())
}
